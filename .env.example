# NetSuite Account Configuration
# Your NetSuite Account ID (e.g. 1234567 or 1234567_SB1 for sandbox)
NS_ACCOUNT_ID=

# OAuth 1.0 Token-Based Authentication (TBA) credentials
# Generate these in NetSuite under Setup > Users/Roles > Access Tokens
NS_CONSUMER_KEY=
NS_CONSUMER_SECRET=
NS_TOKEN_ID=
NS_TOKEN_SECRET=

# Optional: Output directory for downloaded invoices (default: ./invoices)
NS_OUTPUT_DIR=invoices
